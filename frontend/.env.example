# Base HTTP URL for backend REST endpoints.
REACT_APP_BACKEND_URL=http://localhost:8000

# Base URL for live camera/video stream endpoint.
REACT_APP_VIDEO_URL=http://172.20.10.6:8002

# Optional WebSocket base URL. If omitted, it is derived from REACT_APP_BACKEND_URL.
# Example: ws://localhost:8000
REACT_APP_WEBSOCKET_URL=
