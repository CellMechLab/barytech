# Pipeline Configuration for IoT Backend
# Choose ONE mode to avoid duplicate message processing

# PIPELINE_MODE options:
# - "kafka_first"     : Zero-loss ingestion via Kafka-first handler (RECOMMENDED)
# - "per_device"      : Direct per-device topic creation
# - "both"            : Both paths (WARNING: causes message duplication)

PIPELINE_MODE=kafka_first

# Additional Kafka-First Configuration
KAFKA_FIRST_MODE=true
KAFKA_RAW_TOPIC=auto

# Per-Device Configuration (when using per_device mode)
KAFKA_PER_DEVICE_MODE=false

# Monitoring Configuration
ENABLE_BROADCAST=true
SAVE_FLAG=true

# Logging Configuration
VERBOSE_LOGGING=false
LOG_BATCH_SIZE=1000
LOG_COMPRESSION_THRESHOLD=10000



