# Copy to .env and adjust for your network

# Printer service on Raspberry Pi (printer_control_service)
PRINTER_HOST=10.99.134.9
PRINTER_PORT=8001
PRINTER_WS_URL=ws://10.99.134.9:8001/ws
PRINTER_API_URL=http://10.99.134.9:8001

# MQTT broker — localhost for local dev; 10.99.134.9 when broker runs on Pi
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_KEEPALIVE=60
